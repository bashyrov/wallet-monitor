# E2E test credentials. Copy to .env.test (which is gitignored).
# IP-whitelist each key to YOUR local IP (the runner connects from your shell).
# Keep balances ≤ $20-30 per venue — runner enforces hard cap of $18 spent
# per venue and $5 per single order.

# ──────────────────────────────────────────────────────────────────────
# 11 CEX (any subset; runner skips unset keys cleanly)
# ──────────────────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Permission needed: USD-M Futures Trade. Spot read-only is fine if you
# don't want spot-short tested on Binance.

BYBIT_API_KEY=
BYBIT_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

GATE_API_KEY=
GATE_API_SECRET=

MEXC_API_KEY=
MEXC_API_SECRET=

KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

BINGX_API_KEY=
BINGX_API_SECRET=

WHITEBIT_API_KEY=
WHITEBIT_API_SECRET=

KRAKEN_API_KEY=
KRAKEN_API_SECRET=

HTX_API_KEY=
HTX_API_SECRET=

BACKPACK_API_KEY=
BACKPACK_API_SECRET=

# ──────────────────────────────────────────────────────────────────────
# 5 Perp DEX
# ──────────────────────────────────────────────────────────────────────
# Hyperliquid: agent-wallet flow. private_key signs orders; address is the
# main account. Fund the address with USDC (~$30) on HL mainnet/testnet.
HYPERLIQUID_ADDRESS=
HYPERLIQUID_PRIVATE_KEY=

# Aster: HMAC + EIP-712 hybrid. api_key + api_secret(=EVM private key).
ASTER_ADDRESS=
ASTER_API_KEY=
ASTER_API_SECRET=

# Ethereal: EVM-key signing on /v1/place-order (personal_sign).
ETHEREAL_ADDRESS=
ETHEREAL_PRIVATE_KEY=

# Lighter: ZK signing — three creds. account_index numeric, hex pk,
# api_key_index defaults to 255 if blank.
LIGHTER_ACCOUNT_INDEX=
LIGHTER_PRIVATE_KEY=
LIGHTER_API_KEY_INDEX=255

# Paradex: Stark-L2 + JWT. l2_private_key signs orders; api_token is the
# JWT pulled from the Authorization header on any paradex.trade API call
# while signed in.
PARADEX_ADDRESS=
PARADEX_API_TOKEN=
PARADEX_L2_PRIVATE_KEY=

# ──────────────────────────────────────────────────────────────────────
# Test parameters
# ──────────────────────────────────────────────────────────────────────
# Target symbol for trades. Pick a low-price liquid pair so $5 orders
# have meaningful qty and tight spreads. Recommended: BTC, ETH, SOL.
E2E_TEST_SYMBOL=BTC

# Hard caps the runner enforces. If you want a different ceiling, change
# here. Going above $50 per venue requires explicit confirmation each
# time.
E2E_MAX_USD_PER_ORDER=5
E2E_MAX_USD_PER_VENUE=18
E2E_MAX_USD_TOTAL=200

# Logging — every API call goes here.
E2E_LOG_DIR=./e2e_test_logs
