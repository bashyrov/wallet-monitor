# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL (production):
DATABASE_URL=postgresql://user:password@localhost:5432/avalant
# SQLite (local dev — default if not set):
# DATABASE_URL=sqlite:///./wallet_monitor.db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string
ENCRYPTION_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_DAYS=30

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL  (default: INFO)
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Empty = same-origin only (no CORS headers).
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Exchange base URLs (defaults shown — override only if needed) ─────────────
# BINANCE_BASE_URL=https://api.binance.com
# OKX_BASE_URL=https://www.okx.com
# GATE_BASE_URL=https://api.gateio.ws
# MEXC_BASE_URL=https://api.mexc.com
# KUCOIN_BASE_URL=https://api.kucoin.com
# BYBIT_BASE_URL=https://api.bybit.com
# BITGET_BASE_URL=https://api.bitget.com

# ── EVM RPC URLs ──────────────────────────────────────────────────────────────
# Required for chain balance/tx fetching when ANKR_KEY is not set.
# ETHEREUM_RPC=https://mainnet.infura.io/v3/YOUR_KEY
# BSC_RPC=https://bsc-dataseed.binance.org/
# POLYGON_RPC=https://polygon-rpc.com/
# ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
# OPTIMISM_RPC=https://mainnet.optimism.io
# BASE_RPC=https://mainnet.base.org
# AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc
# ZKSYNC_RPC=https://mainnet.era.zksync.io
# LINEA_RPC=https://rpc.linea.build
# SCROLL_RPC=https://rpc.scroll.io
# MANTLE_RPC=https://rpc.mantle.xyz
# BLAST_RPC=https://rpc.blast.io

# ── Ankr ──────────────────────────────────────────────────────────────────────
# Recommended: fetches all ERC-20 token balances and transfers across all EVM chains.
# Without it only native coin balance is returned and tx history is unavailable.
# ANKR_KEY=your_ankr_api_key

# ── CoinMarketCap ─────────────────────────────────────────────────────────────
# Used to fetch top-100 token list for price cache (refreshed every 30 min).
# Without it token prices are not shown (only stablecoin totals).
# CMC_API_KEY=your_coinmarketcap_api_key

# ── Solana ────────────────────────────────────────────────────────────────────
# SOLANA_RPC=https://api.mainnet-beta.solana.com

# ── Tron ──────────────────────────────────────────────────────────────────────
# TronGrid API key — optional, increases rate limits.
# TRON_KEY=your_trongrid_api_key
# TRON_RPC=https://api.trongrid.io
